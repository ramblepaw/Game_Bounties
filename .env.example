# Postgres connection string used by Prisma.
DATABASE_URL="postgresql://tracker:change-me@localhost:5432/tracker?sslmode=disable"

# Secret used to sign session cookies. Generate with: openssl rand -base64 32
AUTH_SECRET="change-me"

# Stable key so Server Actions survive container restarts/rebuilds without
# "Failed to find Server Action" errors. Must be a base64 32-byte AES key.
# Generate with: openssl rand -base64 32
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY="change-me"

# Credentials for the two seeded household accounts. Change before deploying.
# After first `docker compose up`, run once: docker compose exec app npx prisma db seed
SEED_USER_1_USERNAME="player1"
SEED_USER_1_PASSWORD="change-me"
SEED_USER_1_DISPLAY_NAME="Player One"
SEED_USER_2_USERNAME="player2"
SEED_USER_2_PASSWORD="change-me"
SEED_USER_2_DISPLAY_NAME="Player Two"

# IGDB game metadata lookup (used on the "Add game" search). Requires a free
# Twitch Developer app: https://dev.twitch.tv/console/apps/create
IGDB_CLIENT_ID="change-me"
IGDB_CLIENT_SECRET="change-me"

# Docker Compose only: bind-mount paths on the TrueNAS host (ZFS dataset paths).
POSTGRES_PASSWORD="change-me"
UPLOADS_PATH="./data/uploads"
DB_DATA_PATH="./data/postgres"
